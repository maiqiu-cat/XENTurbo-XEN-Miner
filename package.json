{
  "name": "standalone-miner",
  "version": "1.0.0",
  "description": "XENTurbo XEN Miner - pure frontend batch miner, no backend, no database. All state derived from on-chain data.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:create2": "node scripts/verify-create2.mjs",
    "typecheck": "vue-tsc --noEmit",
    "check:bundle": "node scripts/check-bundle-size.mjs"
  },
  "dependencies": {
    "ethers": "^6.13.2",
    "pinia": "^2.2.2",
    "vue": "^3.4.38"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.3",
    "playwright": "^1.61.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.3",
    "vitest": "^2.0.5",
    "vue-tsc": "^2.1.4"
  }
}
